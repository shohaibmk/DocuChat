PROJECT_NAME=DocuChat
DEBUG=False #SQLAlchemy debug mode
API_V1_PREFIX=/api/v1
LOG_LEVEL=DEBUG #Logging level

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://0.0.0.0:3000

# Database configuration
DB_USER=postgres.*
DB_PASSWORD="Your-Password"
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

# Security
SECRET_KEY=replace-with-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Document expiry in seconds (30 minutes)
DOCUMENT_EXPIRY=1800
# Chat expiry in seconds (24 hours)
CHAT_EXPIRY=86400

# S3 / S3-compatible storage (Supabase, MinIO, R2, AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
S3_UPLOAD_PREFIX=uploads/
S3_PRESIGN_EXPIRES=600
S3_MAX_UPLOAD_BYTES=157286400
